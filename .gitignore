# Virtual environment
.venv/
.venv-gpu/

# Python cache
__pycache__/
*.py[cod]
*.so

# Packaging
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.cursor/*
!.cursor/rules/

# Upstream clone (separate git repo)
upstream/

# Environment / secrets
.env
.env.*

# Local-only artifacts
unsloth_compiled_cache/
gpu_env_report.txt

# Test / lint / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.log

# Data artifacts (keep folder structure only)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Run outputs (keep structure, ignore contents)
outputs/logs/*
!outputs/logs/.gitkeep
outputs/predictions/*
!outputs/predictions/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
# Heavy training checkpoints and API caches (paths still documented in research_log)
outputs/ssc/
outputs/llama/
outputs/prompting/
# Review outputs: ignore all by default; keep only selected package trackable
outputs/review/*
!outputs/review/prompting_rawtxt_nonfree_familyB_reasoning-off_2026-05-16/
!outputs/review/prompting_rawtxt_nonfree_familyB_reasoning-off_2026-05-16/**

# Explicitly keep key planning/manifest files tracked
!docs/PROJECT_PLAN.md
!docs/PROMPTING_RESULTS_REPORT.md
!docs/2025.naacl-long.500.pdf
!data/manifest_raw_txt.json

# OS files
.DS_Store
