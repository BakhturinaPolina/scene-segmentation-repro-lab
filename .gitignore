# Virtual environment
.venv/
.venv-gpu/

# Python cache
__pycache__/
*.py[cod]
*.so

# Packaging
build/
dist/
*.egg-info/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.cursor/*
!.cursor/rules/

# Upstream clone (separate git repo)
upstream/

# Environment / secrets
.env
.env.*

# Local-only artifacts
unsloth_compiled_cache/
gpu_env_report.txt

# Test / lint / coverage caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
*.log

# Data artifacts (keep folder structure only)
data/raw/*
!data/raw/.gitkeep
data/interim/*
!data/interim/.gitkeep
data/processed/*
!data/processed/.gitkeep

# Run outputs (keep structure, ignore contents)
outputs/logs/*
!outputs/logs/.gitkeep
outputs/predictions/*
!outputs/predictions/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
# Heavy training checkpoints and API caches (paths still documented in research_log)
outputs/ssc/
outputs/llama/
outputs/prompting/
# Human-review markdown files (German and English translation) are small and worth tracking
!outputs/review/
!outputs/review/en/

# OS files
.DS_Store
